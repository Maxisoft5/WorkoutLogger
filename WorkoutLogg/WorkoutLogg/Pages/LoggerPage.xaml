<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="WorkoutLogg.Pages.LoggerPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:WorkoutLogg.Pages.Controls"
    xmlns:vm="clr-namespace:WorkoutLogg.PageModels"
    BackgroundColor="#EEEEF6"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="20,52,20,12" Spacing="16">

                <!-- Header -->
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                        <Label FontAttributes="Bold" FontSize="28" Text="Logger" TextColor="#111827" />
                        <Label x:Name="DateLabel" FontSize="14" Text="Today" TextColor="#9CA3AF" />
                    </VerticalStackLayout>
                    <Border Grid.Column="1"
                            BackgroundColor="#7C3AED"
                            Padding="14,10"
                            StrokeShape="RoundRectangle 14"
                            StrokeThickness="0"
                            VerticalOptions="Center">
                        <Label FontAttributes="Bold"
                               FontSize="22"
                               Text="+"
                               TextColor="White"
                               VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnAddLogTapped" />
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>
                </Grid>

                <!-- Calendar for day selection -->
                <controls:CalendarPicker
                    x:Name="Calendar"
                    AccentColor="#7C3AED"
                    DateSelected="OnDateSelected" />

                <!-- Sessions list -->
                <CollectionView x:Name="SessionsList"
                                ItemsSource="{Binding Sessions}"
                                SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="12" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:LogSessionDisplayItem">
                            <Border BackgroundColor="White"
                                    Padding="16,14"
                                    Stroke="#F3F4F6"
                                    StrokeShape="RoundRectangle 16"
                                    StrokeThickness="1">
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">

                                    <!-- Icon -->
                                    <Border Grid.Column="0"
                                            BackgroundColor="{Binding BadgeColor}"
                                            HeightRequest="68"
                                            WidthRequest="68"
                                            StrokeShape="RoundRectangle 14"
                                            StrokeThickness="0"
                                            VerticalOptions="Center">
                                        <Label FontSize="22"
                                               HorizontalOptions="Center"
                                               Text="{Binding Emoji}"
                                               VerticalOptions="Center" />
                                    </Border>

                                    <!-- Title + sub -->
                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                                        <Label FontAttributes="Bold"
                                               FontSize="15"
                                               Text="{Binding Title}"
                                               TextColor="#111827" />
                                        <Label FontSize="12"
                                               Text="{Binding SubLabel}"
                                               TextColor="#9CA3AF" />
                                        <Border BackgroundColor="{Binding BadgeColor}"
                                                Padding="6,3"
                                                StrokeShape="RoundRectangle 6"
                                                StrokeThickness="0"
                                                HorizontalOptions="Start">
                                            <Label FontAttributes="Bold"
                                                   FontSize="10"
                                                   Text="{Binding BadgeText}"
                                                   TextColor="{Binding BadgeTextColor}" />
                                        </Border>
                                    </VerticalStackLayout>

                                    <!-- Weight + options -->
                                    <VerticalStackLayout Grid.Column="2"
                                                         HorizontalOptions="End"
                                                         VerticalOptions="Center"
                                                         Spacing="6">
                                        <Label FontAttributes="Bold"
                                               FontSize="13"
                                               HorizontalOptions="End"
                                               Text="{Binding WeightLabel}"
                                               TextColor="#7C3AED" />
                                        <Label FontAttributes="Bold"
                                               FontSize="20"
                                               HorizontalOptions="End"
                                               Text="⋮"
                                               TextColor="#9CA3AF"
                                               Padding="4,0">
                                            <Label.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Tapped="OnSessionOptionsTapped"
                                                    CommandParameter="{Binding Id}" />
                                            </Label.GestureRecognizers>
                                        </Label>
                                    </VerticalStackLayout>

                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Empty state -->
                <VerticalStackLayout IsVisible="{Binding IsEmpty}"
                                     Padding="0,32"
                                     Spacing="10"
                                     HorizontalOptions="Center">
                    <Label FontSize="40" HorizontalOptions="Center" Text="📓" />
                    <Label FontAttributes="Bold"
                           FontSize="16"
                           HorizontalOptions="Center"
                           Text="No workouts logged"
                           TextColor="#111827" />
                    <Label FontSize="14"
                           HorizontalOptions="Center"
                           Text="Tap + to log your workout"
                           TextColor="#9CA3AF" />
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <controls:MainTabBar Grid.Row="1" ActiveTab="Logger" />

    </Grid>
</ContentPage>
