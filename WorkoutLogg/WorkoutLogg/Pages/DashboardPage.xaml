<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="WorkoutLogg.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:WorkoutLogg.Pages.Controls"
    xmlns:loc="clr-namespace:WorkoutLogg.Localization"
    BackgroundColor="#EEEEF6"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="20,52,20,12" Spacing="16">

                <!-- Header -->
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                        <Label x:Name="DateLabel" CharacterSpacing="1" FontAttributes="Bold" FontSize="11" TextColor="#9CA3AF" />
                        <Label x:Name="HelloUserText"
                               FontAttributes="Bold"
                               FontSize="24"
                               TextColor="#111827"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                    <Border Grid.Column="1"
                            BackgroundColor="#7C3AED"
                            HeightRequest="68"
                            WidthRequest="68"
                            StrokeShape="RoundRectangle 14"
                            StrokeThickness="0"
                            VerticalOptions="Center">
                        <Label x:Name="AvatarLabel"
                               FontAttributes="Bold"
                               FontSize="18"
                               HorizontalOptions="Center"
                               TextColor="White"
                               VerticalOptions="Center" />
                    </Border>
                </Grid>

                <!-- Stats Cards Row -->
                <Grid ColumnDefinitions="*,8,*,8,*">
                    <!-- Total Workouts -->
                    <Border Grid.Column="0" BackgroundColor="White" Padding="14,14"
                            Stroke="#F3F4F6" StrokeShape="RoundRectangle 16" StrokeThickness="1">
                        <VerticalStackLayout Spacing="2">
                            <Label FontSize="20" Text="🏋️" />
                            <Label x:Name="TotalWorkoutsLabel" FontAttributes="Bold" FontSize="24" TextColor="#111827" Text="0" />
                            <Label x:Name="WeeklyChangeLabel" FontAttributes="Bold" FontSize="11" TextColor="#7C3AED" Text="+0 this week" />
                            <Label FontSize="11" Text="{loc:Translate Dashboard_TotalWorkouts}" TextColor="#9CA3AF" />
                        </VerticalStackLayout>
                    </Border>
                    <!-- Streak -->
                    <Border Grid.Column="2" BackgroundColor="White" Padding="14,14"
                            Stroke="#F3F4F6" StrokeShape="RoundRectangle 16" StrokeThickness="1">
                        <VerticalStackLayout Spacing="2">
                            <Label FontSize="20" Text="🔥" />
                            <Label x:Name="StreakLabel" FontAttributes="Bold" FontSize="24" TextColor="#111827" Text="0" />
                            <Label FontSize="11" Text="{loc:Translate Dashboard_DayStreak}" TextColor="#7C3AED" />
                            <Label FontSize="11" Text="{loc:Translate Dashboard_Streak}" TextColor="#9CA3AF" />
                        </VerticalStackLayout>
                    </Border>
                    <!-- Volume -->
                    <Border Grid.Column="4" BackgroundColor="White" Padding="14,14"
                            Stroke="#F3F4F6" StrokeShape="RoundRectangle 16" StrokeThickness="1">
                        <VerticalStackLayout Spacing="2">
                            <Label FontSize="20" Text="⚡" />
                            <Label x:Name="WeekVolumeLabel" FontAttributes="Bold" FontSize="24" TextColor="#111827" Text="0 kg" />
                            <Label FontAttributes="Bold" FontSize="11" Text="{loc:Translate Dashboard_ThisWeek}" TextColor="#7C3AED" />
                            <Label FontSize="11" Text="{loc:Translate Dashboard_Volume}" TextColor="#9CA3AF" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- Weekly Activity -->
                <Border BackgroundColor="White" Padding="18,16"
                        Stroke="#F3F4F6" StrokeShape="RoundRectangle 16" StrokeThickness="1">
                    <VerticalStackLayout Spacing="16">
                        <Label FontAttributes="Bold" FontSize="16" Text="{loc:Translate Dashboard_WeeklyActivity}" TextColor="#111827" />
                        <!-- Bar chart built in code-behind -->
                        <Grid x:Name="WeeklyBarsGrid" HeightRequest="90" ColumnSpacing="6" />
                    </VerticalStackLayout>
                </Border>

                <!-- Goals -->
                <Border BackgroundColor="White" Padding="18,16"
                        Stroke="#F3F4F6" StrokeShape="RoundRectangle 16" StrokeThickness="1">
                    <VerticalStackLayout Spacing="16">
                        <Label FontAttributes="Bold" FontSize="16" Text="{loc:Translate Dashboard_WeeklyGoals}" TextColor="#111827" />
                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">

                            <!-- Workouts goal -->
                            <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="6">
                                <Border BackgroundColor="#F3F0FF" HeightRequest="74" WidthRequest="74"
                                        StrokeShape="Ellipse" StrokeThickness="0" HorizontalOptions="Center">
                                    <Label x:Name="WorkoutsGoalPct" FontAttributes="Bold" FontSize="14"
                                           HorizontalOptions="Center" TextColor="#7C3AED" VerticalOptions="Center" Text="0%" />
                                </Border>
                                <Label x:Name="WorkoutsGoalSub" FontSize="11" HorizontalOptions="Center"
                                       TextColor="#6B7280" Text="0 / 4" />
                                <Label FontSize="11" HorizontalOptions="Center" Text="{loc:Translate Dashboard_Workouts}" TextColor="#9CA3AF" />
                            </VerticalStackLayout>

                            <!-- Volume goal -->
                            <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="6">
                                <Border BackgroundColor="#F3F0FF" HeightRequest="74" WidthRequest="74"
                                        StrokeShape="Ellipse" StrokeThickness="0" HorizontalOptions="Center">
                                    <Label x:Name="VolumeGoalPct" FontAttributes="Bold" FontSize="14"
                                           HorizontalOptions="Center" TextColor="#7C3AED" VerticalOptions="Center" Text="0%" />
                                </Border>
                                <Label x:Name="VolumeGoalSub" FontSize="11" HorizontalOptions="Center"
                                       TextColor="#6B7280" Text="0 / 5 000" />
                                <Label FontSize="11" HorizontalOptions="Center" Text="{loc:Translate Dashboard_VolumeKg}" TextColor="#9CA3AF" />
                            </VerticalStackLayout>

                            <!-- Consistency goal -->
                            <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="6">
                                <Border BackgroundColor="#F3F0FF" HeightRequest="74" WidthRequest="74"
                                        StrokeShape="Ellipse" StrokeThickness="0" HorizontalOptions="Center">
                                    <Label x:Name="ConsistencyGoalPct" FontAttributes="Bold" FontSize="14"
                                           HorizontalOptions="Center" TextColor="#7C3AED" VerticalOptions="Center" Text="0%" />
                                </Border>
                                <Label x:Name="ConsistencyGoalSub" FontSize="11" HorizontalOptions="Center"
                                       TextColor="#6B7280" Text="0 / 5" />
                                <Label FontSize="11" HorizontalOptions="Center" Text="{loc:Translate Dashboard_ActiveDays}" TextColor="#9CA3AF" />
                            </VerticalStackLayout>

                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Last Workout -->
                <Border BackgroundColor="White" Padding="18,16"
                        Stroke="#F3F4F6" StrokeShape="RoundRectangle 16" StrokeThickness="1">
                    <VerticalStackLayout Spacing="14">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Grid.Column="0" FontAttributes="Bold" FontSize="16" Text="{loc:Translate Dashboard_LastWorkout}" TextColor="#111827" />
                            <Label Grid.Column="1" FontAttributes="Bold" FontSize="13" Text="{loc:Translate Dashboard_SeeAll}" TextColor="#7C3AED">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnSeeAllWorkoutsTapped" />
                                </Label.GestureRecognizers>
                            </Label>
                        </Grid>

                        <!-- Has workout -->
                        <Grid x:Name="LastWorkoutCard" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                            <Border Grid.Column="0"
                                    BackgroundColor="#EDE9FE"
                                    HeightRequest="72"
                                    WidthRequest="72"
                                    StrokeShape="RoundRectangle 14"
                                    StrokeThickness="0"
                                    VerticalOptions="Center">
                                <Label x:Name="LastWorkoutEmoji" FontSize="24"
                                       HorizontalOptions="Center" VerticalOptions="Center" Text="🏋️" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="3">
                                <Label x:Name="LastWorkoutTitle" FontAttributes="Bold" FontSize="15"
                                       TextColor="#111827" Text="—" />
                                <Label x:Name="LastWorkoutSub" FontSize="12" TextColor="#9CA3AF" Text="—" />
                            </VerticalStackLayout>
                            <Label x:Name="LastWorkoutVolume" Grid.Column="2"
                                   FontAttributes="Bold" FontSize="14"
                                   TextColor="#7C3AED" VerticalOptions="Center" Text="—" />
                        </Grid>

                        <!-- No workout placeholder -->
                        <Label x:Name="NoWorkoutLabel"
                               IsVisible="False"
                               FontSize="13"
                               TextColor="#9CA3AF"
                               HorizontalOptions="Center"
                               Text="{loc:Translate Dashboard_NoWorkouts}" />

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <controls:MainTabBar Grid.Row="1" ActiveTab="Dashboard" />

    </Grid>
</ContentPage>
