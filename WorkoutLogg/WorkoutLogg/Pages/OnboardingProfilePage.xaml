<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="WorkoutLogg.Pages.OnboardingProfilePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:loc="clr-namespace:WorkoutLogg.Localization"
    BackgroundColor="#EEEEF6"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*,Auto" Padding="0">

        <!-- Step indicator -->
        <HorizontalStackLayout Grid.Row="0" HorizontalOptions="Center" Margin="0,52,0,32" Spacing="6">
            <BoxView CornerRadius="3" HeightRequest="6" WidthRequest="28" Color="#7C3AED" />
            <BoxView CornerRadius="3" HeightRequest="6" WidthRequest="10" Color="#D1D5DB" />
            <BoxView CornerRadius="3" HeightRequest="6" WidthRequest="10" Color="#D1D5DB" />
        </HorizontalStackLayout>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="28,0" Spacing="0">

                <!-- Step label -->
                <Label CharacterSpacing="1" FontAttributes="Bold" FontSize="11" Margin="0,0,0,10" Text="{loc:Translate Onboarding_Step1}" TextColor="#9CA3AF" />

                <!-- Title -->
                <Label FontAttributes="Bold" FontSize="28" Margin="0,0,0,8" Text="{loc:Translate Onboarding_ProfileTitle}" TextColor="#111827" />
                <Label FontSize="14" Margin="0,0,0,36" Text="{loc:Translate Onboarding_ProfileSubtitle}" TextColor="#9CA3AF" />

                <!-- Avatar -->
                <Grid HorizontalOptions="Center" Margin="0,0,0,36" WidthRequest="150" HeightRequest="150">
                    <Border
                        BackgroundColor="#7C3AED"
                        HeightRequest="120"
                        HorizontalOptions="Center"
                        StrokeShape="RoundRectangle 22"
                        StrokeThickness="0"
                        VerticalOptions="Center"
                        WidthRequest="120">
                        <Label
                            x:Name="AvatarLabel"
                            FontAttributes="Bold"
                            FontSize="36"
                            HorizontalOptions="Center"
                            Text="A"
                            TextColor="White"
                            VerticalOptions="Center" />
                    </Border>
                    <!-- Edit badge -->
                    <Border
                        BackgroundColor="#374151"
                        HeightRequest="56"
                        HorizontalOptions="End"
                        StrokeShape="RoundRectangle 8"
                        StrokeThickness="0"
                        VerticalOptions="End"
                        WidthRequest="56">
                        <Label FontSize="13" HorizontalOptions="Center" Text="✏️" VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnChangeAvatarTapped" />
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>
                </Grid>

                <!-- DATE OF BIRTH -->
                <Label CharacterSpacing="1.2" FontAttributes="Bold" FontSize="11" Margin="4,0,0,8" Text="{loc:Translate Onboarding_DateOfBirth}" TextColor="#6B7280" />
                <Border Margin="0,0,0,16" BackgroundColor="White" Stroke="#E5E7EB" StrokeShape="RoundRectangle 12" StrokeThickness="1.5">
                    <DatePicker
                        x:Name="BirthDatePicker"
                        BackgroundColor="Transparent"
                        Format="dd / MM / yyyy"
                        FontSize="15"
                        Margin="14,0"
                        TextColor="#111827"
                        VerticalOptions="Center"
                        xmlns:sys="clr-namespace:System;assembly=netstandard" />
                </Border>

                <!-- BIOLOGICAL SEX -->
                <Label CharacterSpacing="1.2" FontAttributes="Bold" FontSize="11" Margin="4,0,0,12" Text="{loc:Translate Onboarding_BiologicalSex}" TextColor="#6B7280" />
                <HorizontalStackLayout Margin="0,0,0,8" Spacing="10">
                    <Border x:Name="MaleBorder" BackgroundColor="#7C3AED" StrokeShape="RoundRectangle 12" StrokeThickness="0" WidthRequest="100">
                        <Button x:Name="MaleButton" BackgroundColor="Transparent" Clicked="OnMaleSelected" FontAttributes="Bold" FontSize="14" Text="{loc:Translate Onboarding_Male}" TextColor="White" />
                    </Border>
                    <Border x:Name="FemaleBorder" BackgroundColor="White" Stroke="#E5E7EB" StrokeShape="RoundRectangle 12" StrokeThickness="1.5" WidthRequest="100">
                        <Button x:Name="FemaleButton" BackgroundColor="Transparent" Clicked="OnFemaleSelected" FontAttributes="Bold" FontSize="14" Text="{loc:Translate Onboarding_Female}" TextColor="#374151" />
                    </Border>
                </HorizontalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Continue Button -->
        <Border Grid.Row="2" Margin="28,16,28,40" StrokeShape="RoundRectangle 14" StrokeThickness="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#7C3AED" Offset="0" />
                    <GradientStop Color="#9333EA" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Button BackgroundColor="Transparent" Clicked="OnContinueClicked" FontAttributes="Bold" FontSize="16" Text="{loc:Translate Common_Continue}" TextColor="White" />
        </Border>

    </Grid>
</ContentPage>
