<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="WorkoutLogg.Pages.PasswordSuccess"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:loc="clr-namespace:WorkoutLogg.Localization"
    BackgroundColor="#EEEEF6"
    Shell.NavBarIsVisible="False">
    <ScrollView>
    <VerticalStackLayout Padding="28,52,28,40" Spacing="0">

        <!-- Back -->
        <HorizontalStackLayout Margin="0,0,0,36" Spacing="8">
            <Border BackgroundColor="White" StrokeShape="RoundRectangle 10" StrokeThickness="0">
                <Label FontSize="16" HorizontalOptions="Center" Text="←" TextColor="#374151" VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackTapped" />
                    </Label.GestureRecognizers>
                </Label>
            </Border>
            <Label FontSize="15" Text="{loc:Translate Common_Back}" TextColor="#374151" VerticalOptions="Center">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackTapped" />
                </Label.GestureRecognizers>
            </Label>
        </HorizontalStackLayout>

        <!-- Green check icon -->
        <Border
            Margin="0,0,0,28"
            BackgroundColor="#22C55E"
            HorizontalOptions="Center"
            StrokeShape="RoundRectangle 22"
            StrokeThickness="0">
            <Label FontSize="36" HorizontalOptions="Center" Text="✅" VerticalOptions="Center" />
        </Border>

        <!-- Title -->
        <Label FontAttributes="Bold" FontSize="26" HorizontalOptions="Center" HorizontalTextAlignment="Center" Margin="0,0,0,8" Text="{loc:Translate PasswordSuccess_Title}" TextColor="#111827" />
        <Label FontSize="14" HorizontalOptions="Center" HorizontalTextAlignment="Center" Margin="0,0,0,36" Text="{loc:Translate PasswordSuccess_Subtitle}" TextColor="#9CA3AF" />

        <!-- Success banner -->
        <Border
            Margin="0,0,0,32"
            BackgroundColor="#DCFCE7"
            Padding="20,18"
            Stroke="#BBF7D0"
            StrokeShape="RoundRectangle 14"
            StrokeThickness="1.5">
            <Label
                FontAttributes="Bold"
                FontSize="14"
                HorizontalOptions="Center"
                HorizontalTextAlignment="Center"
                LineBreakMode="WordWrap"
                Text="{loc:Translate PasswordSuccess_Banner}"
                TextColor="#16A34A" />
        </Border>

        <!-- Back to Sign In -->
        <Border StrokeShape="RoundRectangle 14" StrokeThickness="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#7C3AED" Offset="0" />
                    <GradientStop Color="#9333EA" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Button BackgroundColor="Transparent" Clicked="OnBackToSignInClicked" FontAttributes="Bold" FontSize="16" Text="{loc:Translate PasswordSuccess_BackToSignIn}" TextColor="White" />
        </Border>

    </VerticalStackLayout>
    </ScrollView>
</ContentPage>
