<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="WorkoutLogg.Pages.OnboardingGoalsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#EEEEF6"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*,Auto" Padding="0">

        <!-- Step indicator -->
        <HorizontalStackLayout Grid.Row="0" HorizontalOptions="Center" Margin="0,52,0,32" Spacing="6">
            <BoxView CornerRadius="3" HeightRequest="6" WidthRequest="10" Color="#D1D5DB" />
            <BoxView CornerRadius="3" HeightRequest="6" WidthRequest="10" Color="#D1D5DB" />
            <BoxView CornerRadius="3" HeightRequest="6" WidthRequest="28" Color="#7C3AED" />
        </HorizontalStackLayout>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="28,0" Spacing="0">

                <!-- Step label -->
                <Label CharacterSpacing="1" FontAttributes="Bold" FontSize="11" Margin="0,0,0,10" Text="STEP 3 OF 3" TextColor="#9CA3AF" />
                <Label FontAttributes="Bold" FontSize="28" Margin="0,0,0,8" Text="What are your goals?" TextColor="#111827" />
                <Label FontSize="14" Margin="0,0,0,28" Text="Pick one or more — we'll tailor your plan" TextColor="#9CA3AF" />

                <!-- Goal: Lose Fat (initially selected) -->
                <Border x:Name="LoseFatBorder" Margin="0,0,0,12" BackgroundColor="White" 
                        Padding="16,14" Stroke="#E5E7EB" StrokeShape="RoundRectangle 16" StrokeThickness="1.5">
                    <Grid ColumnDefinitions="100,*,82">
                        <Border Grid.Column="0" BackgroundColor="#FEF3C7" HeightRequest="100" 
                                StrokeShape="RoundRectangle 12" StrokeThickness="0" WidthRequest="100" VerticalOptions="Center">
                            <Label FontSize="22" HorizontalOptions="Center" Text="🔥" VerticalOptions="Center" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Margin="14,0,0,0" VerticalOptions="Center">
                            <Label FontAttributes="Bold" FontSize="16" Text="Lose Fat" TextColor="#111827" />
                            <Label FontSize="12" Text="Reduce body fat percentage" TextColor="#9CA3AF" />
                        </VerticalStackLayout>
                        <Border Grid.Column="2" BackgroundColor="#7C3AED" HeightRequest="70"
                                StrokeShape="RoundRectangle 8" StrokeThickness="0" VerticalOptions="Center" WidthRequest="70">
                            <Label x:Name="FatGoal" FontSize="14" HorizontalOptions="Center" Text="" TextColor="White" VerticalOptions="Center" />
                        </Border>
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnGoalTapped" CommandParameter="LoseFat" />
                    </Border.GestureRecognizers>
                </Border>

                <!-- Goal: Build Muscle -->
                <Border x:Name="BuildMuscleBorder" Margin="0,0,0,12" BackgroundColor="White" Padding="16,14" 
                        Stroke="#E5E7EB" StrokeShape="RoundRectangle 16" StrokeThickness="1.5">
                    <Grid ColumnDefinitions="100,*,82">
                        <Border Grid.Column="0" BackgroundColor="#FEF3C7" HeightRequest="100" 
                                StrokeShape="RoundRectangle 12" StrokeThickness="0" WidthRequest="100" 
                                VerticalOptions="Center">
                            <Label FontSize="22" HorizontalOptions="Center" Text="💪" VerticalOptions="Center" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Margin="14,0,0,0" VerticalOptions="Center">
                            <Label FontAttributes="Bold" FontSize="16" Text="Build Muscle" TextColor="#111827" />
                            <Label FontSize="14" Text="Increase muscle mass &amp; strength" TextColor="#9CA3AF" />
                        </VerticalStackLayout>
                        <Border Grid.Column="2" BackgroundColor="#7C3AED" HeightRequest="70" 
                                    StrokeShape="RoundRectangle 8" StrokeThickness="0" VerticalOptions="Center" WidthRequest="70">
                            <Label x:Name="BuildMuscleGoal" FontSize="14" HorizontalOptions="Center" Text="" TextColor="White" VerticalOptions="Center" />
                        </Border>
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnGoalTapped" CommandParameter="BuildMuscle" />
                    </Border.GestureRecognizers>
                </Border>

                <!-- Goal: Improve Endurance -->
                <Border x:Name="EnduranceBorder" Margin="0,0,0,12" BackgroundColor="White" Padding="16,14" Stroke="#E5E7EB" StrokeShape="RoundRectangle 16" StrokeThickness="1.5">
                    <Grid ColumnDefinitions="100,*,82">
                        <Border Grid.Column="0" BackgroundColor="#E0F2FE" HeightRequest="100" StrokeShape="RoundRectangle 12" 
                                StrokeThickness="0" WidthRequest="100" VerticalOptions="Center">
                            <Label FontSize="22" HorizontalOptions="Center" Text="🏃" VerticalOptions="Center" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Margin="14,0,0,0" VerticalOptions="Center">
                            <Label FontAttributes="Bold" FontSize="16" Text="Improve Endurance" TextColor="#111827" />
                            <Label FontSize="12" Text="Cardio &amp; stamina training" TextColor="#9CA3AF" />
                        </VerticalStackLayout>
                        <Border Grid.Column="2" BackgroundColor="#7C3AED" HeightRequest="70" 
                                StrokeShape="RoundRectangle 8" StrokeThickness="0" VerticalOptions="Center" WidthRequest="70">
                            <Label x:Name="EnduranceGoal" FontSize="14" HorizontalOptions="Center" Text="" 
                                   TextColor="White" VerticalOptions="Center" />
                        </Border>
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnGoalTapped" CommandParameter="Endurance" />
                    </Border.GestureRecognizers>
                </Border>

                <!-- Goal: Increase Strength -->
                <Border x:Name="StrengthBorder" Margin="0,0,0,12" BackgroundColor="White" Padding="16,14" Stroke="#E5E7EB" StrokeShape="RoundRectangle 16" StrokeThickness="1.5">
                    <Grid ColumnDefinitions="100,*,82">
                        <Border Grid.Column="0" BackgroundColor="#FEF9C3" HeightRequest="100" 
                                StrokeShape="RoundRectangle 12" StrokeThickness="0" WidthRequest="100" VerticalOptions="Center">
                            <Label FontSize="22" HorizontalOptions="Center" Text="⚡" VerticalOptions="Center" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Margin="14,0,0,0" VerticalOptions="Center">
                            <Label FontAttributes="Bold" FontSize="16" Text="Increase Strength" TextColor="#111827" />
                            <Label FontSize="12" Text="Hit new personal records" TextColor="#9CA3AF" />
                        </VerticalStackLayout>
                        <Border Grid.Column="2" BackgroundColor="#7C3AED" HeightRequest="70"
                                StrokeShape="RoundRectangle 8" StrokeThickness="0" VerticalOptions="Center" WidthRequest="70">
                            <Label x:Name="StrengthCheckGoal" FontSize="14" HorizontalOptions="Center" Text="" 
                                   TextColor="White" VerticalOptions="Center" />
                        </Border>
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnGoalTapped" CommandParameter="Strength" />
                    </Border.GestureRecognizers>
                </Border>

                <!-- Goal: Flexibility -->
                <Border x:Name="FlexibilityBorder" Margin="0,0,0,12" BackgroundColor="White" Padding="16,14" Stroke="#E5E7EB" StrokeShape="RoundRectangle 16" StrokeThickness="1.5">
                    <Grid ColumnDefinitions="100,*,82">
                        <Border Grid.Column="0" BackgroundColor="#FCE7F3" HeightRequest="100" 
                                StrokeShape="RoundRectangle 12" StrokeThickness="0" WidthRequest="100" VerticalOptions="Center">
                            <Label FontSize="22" HorizontalOptions="Center" Text="🧘" VerticalOptions="Center" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Margin="14,0,0,0" VerticalOptions="Center">
                            <Label FontAttributes="Bold" FontSize="16" Text="Flexibility" TextColor="#111827" />
                            <Label FontSize="12" Text="Yoga, mobility &amp; stretching" TextColor="#9CA3AF" />
                        </VerticalStackLayout>
                        <Border Grid.Column="2" BackgroundColor="#7C3AED" HeightRequest="70" 
          StrokeShape="RoundRectangle 8" StrokeThickness="0" VerticalOptions="Center" WidthRequest="70">
                            <Label x:Name="FlexibilityCheckGoal" FontSize="14" HorizontalOptions="Center" Text="" 
             TextColor="White" VerticalOptions="Center" />
                        </Border>
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnGoalTapped" CommandParameter="Flexibility" />
                    </Border.GestureRecognizers>
                </Border>

                <!-- Goal: Stay Active -->
                <Border x:Name="StayActiveBorder" Margin="0,0,0,28" BackgroundColor="White" Padding="16,14" Stroke="#E5E7EB" StrokeShape="RoundRectangle 16" StrokeThickness="1.5">
                    <Grid ColumnDefinitions="100,*,82">
                        <Border Grid.Column="0" BackgroundColor="#FEF3C7" HeightRequest="100" 
                                StrokeShape="RoundRectangle 12" StrokeThickness="0" WidthRequest="100" VerticalOptions="Center">
                            <Label FontSize="22" HorizontalOptions="Center" Text="🌟" VerticalOptions="Center" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Margin="14,0,0,0" VerticalOptions="Center">
                            <Label FontAttributes="Bold" FontSize="16" Text="Stay Active" TextColor="#111827" />
                            <Label FontSize="12" Text="General fitness &amp; health" TextColor="#9CA3AF" />
                        </VerticalStackLayout>
                        <Border Grid.Column="2" BackgroundColor="#7C3AED" HeightRequest="70" 
StrokeShape="RoundRectangle 8" StrokeThickness="0" VerticalOptions="Center" WidthRequest="70">
                            <Label x:Name="StayActiveCheckGoal" FontSize="14" HorizontalOptions="Center" Text="" 
   TextColor="White" VerticalOptions="Center" />
                        </Border>
                    </Grid>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnGoalTapped" CommandParameter="StayActive" />
                    </Border.GestureRecognizers>
                </Border>

                <!-- Workouts per week -->
                <Label CharacterSpacing="1.2" FontAttributes="Bold" FontSize="11" 
                       Margin="4,0,0,14" Text="WORKOUTS PER WEEK" TextColor="#6B7280" />
                <HorizontalStackLayout Margin="0,0,0,12" Spacing="10">
                    <Border x:Name="W1Border" BackgroundColor="White" Stroke="#E5E7EB" StrokeShape="RoundRectangle 12" StrokeThickness="1.5">
                        <Button x:Name="W1Button" BackgroundColor="Transparent" Clicked="OnWorkoutFreqTapped" CommandParameter="1" FontAttributes="Bold" FontSize="14" Text="1×" TextColor="#374151" />
                    </Border>
                    <Border x:Name="W2Border" BackgroundColor="White" Stroke="#E5E7EB" StrokeShape="RoundRectangle 12" StrokeThickness="1.5">
                        <Button x:Name="W2Button" BackgroundColor="Transparent" Clicked="OnWorkoutFreqTapped" CommandParameter="2" FontAttributes="Bold" FontSize="14" Text="2×" TextColor="#374151" />
                    </Border>
                    <Border x:Name="W3Border" BackgroundColor="White" Stroke="#E5E7EB" StrokeShape="RoundRectangle 12" StrokeThickness="1.5">
                        <Button x:Name="W3Button" BackgroundColor="Transparent" Clicked="OnWorkoutFreqTapped" CommandParameter="3" FontAttributes="Bold" FontSize="14" Text="3×" TextColor="#374151" />
                    </Border>
                    <Border x:Name="W4Border" BackgroundColor="#7C3AED" StrokeShape="RoundRectangle 12" StrokeThickness="0">
                        <Button x:Name="W4Button" BackgroundColor="Transparent" Clicked="OnWorkoutFreqTapped" CommandParameter="4" FontAttributes="Bold" FontSize="14" Text="4×" TextColor="White" />
                    </Border>
                    <Border x:Name="W5Border" BackgroundColor="White" Stroke="#E5E7EB" StrokeShape="RoundRectangle 12" StrokeThickness="1.5">
                        <Button x:Name="W5Button" BackgroundColor="Transparent" Clicked="OnWorkoutFreqTapped" CommandParameter="5" FontAttributes="Bold" FontSize="14" Text="5×" TextColor="#374151" />
                    </Border>
                    <Border x:Name="W6Border" BackgroundColor="White" Stroke="#E5E7EB" StrokeShape="RoundRectangle 12" StrokeThickness="1.5">
                        <Button x:Name="W6Button" BackgroundColor="Transparent" Clicked="OnWorkoutFreqTapped" CommandParameter="6" FontAttributes="Bold" FontSize="14" Text="6×" TextColor="#374151" />
                    </Border>
                </HorizontalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Finish Button -->
        <Border Grid.Row="2" Margin="28,16,28,40" StrokeShape="RoundRectangle 14" StrokeThickness="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#7C3AED" Offset="0" />
                    <GradientStop Color="#9333EA" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Button BackgroundColor="Transparent" Clicked="OnFinishClicked" FontAttributes="Bold" FontSize="16" Text="Finish →" TextColor="White" />
        </Border>

    </Grid>
</ContentPage>
