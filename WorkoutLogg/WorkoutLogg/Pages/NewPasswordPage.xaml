<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="WorkoutLogg.Pages.NewPasswordPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#EEEEF6"
    Shell.NavBarIsVisible="False">
    <ScrollView>
        <VerticalStackLayout Padding="28,52,28,40" Spacing="0">

        <!-- Back -->
        <HorizontalStackLayout Margin="0,0,0,36" Spacing="8">
            <Border BackgroundColor="White"  StrokeShape="RoundRectangle 10" StrokeThickness="0">
                <Label FontSize="16" HorizontalOptions="Center" Text="←" TextColor="#374151" VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackTapped" />
                    </Label.GestureRecognizers>
                </Label>
            </Border>
            <Label FontSize="15" Text="Back" TextColor="#374151" VerticalOptions="Center">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackTapped" />
                </Label.GestureRecognizers>
            </Label>
        </HorizontalStackLayout>

        <!-- Icon -->
        <Border
            Margin="0,0,0,28"
            BackgroundColor="#7C3AED"
            HeightRequest="100"
            HorizontalOptions="Center"
            StrokeShape="RoundRectangle 22"
            StrokeThickness="0"
            WidthRequest="100">
            <Label FontSize="36" HorizontalOptions="Center" Text="🔑" VerticalOptions="Center" />
        </Border>

        <!-- Title -->
        <Label FontAttributes="Bold" FontSize="26" HorizontalOptions="Center" HorizontalTextAlignment="Center" Margin="0,0,0,8" Text="New password" TextColor="#111827" />
        <Label FontSize="14" HorizontalOptions="Center" HorizontalTextAlignment="Center" Margin="0,0,0,36" Text="Create a strong password for your account" TextColor="#9CA3AF" />

        <!-- NEW PASSWORD -->
        <Label CharacterSpacing="1.2" FontAttributes="Bold" FontSize="11" Margin="4,0,0,8" Text="NEW PASSWORD" TextColor="#6B7280" />
        <Border Margin="0,0,0,16" BackgroundColor="White" Stroke="#E5E7EB" StrokeShape="RoundRectangle 12" StrokeThickness="1.5">
            <Entry x:Name="NewPasswordEntry" BackgroundColor="Transparent" FontSize="15" IsPassword="True" Margin="14,0" Placeholder="••••••••" PlaceholderColor="#D1D5DB" TextChanged="OnPasswordTextChanged" TextColor="#111827" VerticalOptions="Center" />
        </Border>

        <!-- CONFIRM PASSWORD -->
        <Label CharacterSpacing="1.2" FontAttributes="Bold" FontSize="11" Margin="4,0,0,8" Text="CONFIRM PASSWORD" TextColor="#6B7280" />
        <Border Margin="0,0,0,18" BackgroundColor="White" Stroke="#E5E7EB" StrokeShape="RoundRectangle 12" StrokeThickness="1.5">
            <Entry x:Name="ConfirmPasswordEntry" BackgroundColor="Transparent" FontSize="15" IsPassword="True" Margin="14,0" Placeholder="••••••••" PlaceholderColor="#D1D5DB" TextColor="#111827" VerticalOptions="Center" />
        </Border>

        <!-- PASSWORD STRENGTH -->
        <Grid ColumnDefinitions="Auto,*,Auto" Margin="4,0,4,6" VerticalOptions="Center">
            <Label Grid.Column="0" CharacterSpacing="1.2" FontAttributes="Bold" FontSize="11" Text="PASSWORD STRENGTH" TextColor="#6B7280" VerticalOptions="Center" />
            <Label x:Name="StrengthLabel" Grid.Column="2" FontAttributes="Bold" FontSize="12" Text="" TextColor="#22C55E" VerticalOptions="Center" />
        </Grid>

        <!-- Strength bar (3 segments) -->
        <Grid ColumnDefinitions="*,4,*,4,*" Margin="0,0,0,28" HeightRequest="6">
            <BoxView x:Name="Bar0" Grid.Column="0" Color="#E5E7EB" CornerRadius="3" />
            <BoxView x:Name="Bar1" Grid.Column="2" Color="#E5E7EB" CornerRadius="3" />
            <BoxView x:Name="Bar2" Grid.Column="4" Color="#E5E7EB" CornerRadius="3" />
        </Grid>

        <!-- Reset Password -->
            <Border StrokeShape="RoundRectangle 14" StrokeThickness="0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#7C3AED" Offset="0" />
                        <GradientStop Color="#9333EA" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <Button BackgroundColor="Transparent" Clicked="OnResetPasswordClicked" FontAttributes="Bold" FontSize="16" Text="Reset Password" TextColor="White" />
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
