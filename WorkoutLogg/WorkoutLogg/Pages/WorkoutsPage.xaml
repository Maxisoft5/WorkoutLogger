<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="WorkoutLogg.Pages.WorkoutsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:WorkoutLogg.Pages.Controls"
    xmlns:pagemodels="clr-namespace:WorkoutLogg.PageModels"
    xmlns:vm="clr-namespace:WorkoutLogg.PageModels"
    BackgroundColor="#EEEEF6"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="20,52,20,12" Spacing="16">

                <!-- Header -->
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                        <Label FontAttributes="Bold" FontSize="28" Text="Workouts" TextColor="#111827" />
                        <Label x:Name="SessionCountLabel" FontSize="14" Text="0 sessions logged" TextColor="#9CA3AF" />
                    </VerticalStackLayout>
                    <Border Grid.Column="1"
                            BackgroundColor="#7C3AED"
                            Padding="14,10"
                            StrokeShape="RoundRectangle 14"
                            StrokeThickness="0"
                            VerticalOptions="Center">
                        <Label FontAttributes="Bold"
                               FontSize="22"
                               Text="+"
                               TextColor="White"
                               VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnAddWorkoutTapped" />
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>
                </Grid>

                <!-- Filter chips -->
                <ScrollView HorizontalScrollBarVisibility="Never" Orientation="Horizontal">
                    <HorizontalStackLayout Spacing="8">
                        <Border x:Name="FilterAll" BackgroundColor="#7C3AED" Padding="16,8" StrokeShape="RoundRectangle 20" StrokeThickness="0">
                            <Label FontAttributes="Bold" FontSize="13" Text="All" TextColor="White">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnFilterTapped" CommandParameter="All" />
                                </Label.GestureRecognizers>
                            </Label>
                        </Border>
                        <Border x:Name="FilterStrength" BackgroundColor="White" Padding="16,8" Stroke="#E5E7EB" StrokeShape="RoundRectangle 20" StrokeThickness="1.5">
                            <Label FontAttributes="Bold" FontSize="13" Text="Strength" TextColor="#6B7280">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnFilterTapped" CommandParameter="Strength" />
                                </Label.GestureRecognizers>
                            </Label>
                        </Border>
                        <Border x:Name="FilterCardio" BackgroundColor="White" Padding="16,8" Stroke="#E5E7EB" StrokeShape="RoundRectangle 20" StrokeThickness="1.5">
                            <Label FontAttributes="Bold" FontSize="13" Text="Cardio" TextColor="#6B7280">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnFilterTapped" CommandParameter="Cardio" />
                                </Label.GestureRecognizers>
                            </Label>
                        </Border>
                        <Border x:Name="FilterStretch" BackgroundColor="White" Padding="16,8" Stroke="#E5E7EB" StrokeShape="RoundRectangle 20" StrokeThickness="1.5">
                            <Label FontAttributes="Bold" FontSize="13" Text="Stretch" TextColor="#6B7280">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnFilterTapped" CommandParameter="Stretch" />
                                </Label.GestureRecognizers>
                            </Label>
                        </Border>
                    </HorizontalStackLayout>
                </ScrollView>

                <!-- Calendar -->
                <controls:CalendarPicker
                    x:Name="Calendar"
                    AccentColor="#7C3AED"
                    DateSelected="OnDateSelected" />

                <!-- Workout list -->
                <CollectionView x:Name="WorkoutsList" ItemsSource="{Binding Workouts}" SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="12" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:WorkoutDisplayItem">
                            <Border BackgroundColor="White" Padding="16,14" Stroke="#F3F4F6" StrokeShape="RoundRectangle 16" StrokeThickness="1">
                                <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10">
                                    <!-- Icon -->
                                    <Border Grid.Column="0"
                                            BackgroundColor="{Binding IconBackground}"
                                            HeightRequest="68"
                                            WidthRequest="68"
                                            StrokeShape="RoundRectangle 14"
                                            StrokeThickness="0"
                                            VerticalOptions="Center">
                                        <Label FontSize="22"
                                               HorizontalOptions="Center"
                                               Text="{Binding Emoji}"
                                               VerticalOptions="Center" />
                                    </Border>
                                    <!-- Name + subtitle -->
                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                        <Label FontAttributes="Bold" FontSize="15" Text="{Binding TypeLabel}" TextColor="#111827" />
                                        <Label FontSize="12" Text="{Binding SubLabel}" TextColor="#9CA3AF" />
                                    </VerticalStackLayout>
                                    <!-- Weight + type -->
                                    <VerticalStackLayout Grid.Column="2" HorizontalOptions="End" VerticalOptions="Center" Spacing="2">
                                        <Label FontAttributes="Bold"
                                               FontSize="13"
                                               HorizontalOptions="End"
                                               Text="{Binding WeightLabel}"
                                               TextColor="{Binding WeightColor}" />
                                        <Label FontSize="11"
                                               HorizontalOptions="End"
                                               Text="{Binding TypeLabel}"
                                               TextColor="#9CA3AF" />
                                    </VerticalStackLayout>
                                    <!-- Options ⋮ -->
                                    <Label Grid.Column="3"
                                           FontAttributes="Bold"
                                           FontSize="20"
                                           HorizontalOptions="End"
                                           Text="⋮"
                                           TextColor="#9CA3AF"
                                           VerticalOptions="Center"
                                           Padding="4,0">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Tapped="OnWorkoutOptionsTapped"
                                                CommandParameter="{Binding Id}" />
                                        </Label.GestureRecognizers>
                                    </Label>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Empty state (shown when no workouts match the current filter) -->
                <VerticalStackLayout
                    IsVisible="{Binding IsEmpty}"
                    Padding="0,32"
                    Spacing="10"
                    HorizontalOptions="Center">
                    <Label FontSize="40" HorizontalOptions="Center" Text="🏋️" />
                    <Label FontAttributes="Bold"
                           FontSize="16"
                           HorizontalOptions="Center"
                           Text="No workouts yet"
                           TextColor="#111827" />
                    <Label FontSize="14"
                           HorizontalOptions="Center"
                           Text="Tap + to add your first workout"
                           TextColor="#9CA3AF" />
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <controls:MainTabBar Grid.Row="1" ActiveTab="Workouts" />
    </Grid>
</ContentPage>
