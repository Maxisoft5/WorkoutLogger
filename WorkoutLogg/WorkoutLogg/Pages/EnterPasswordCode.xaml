<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="WorkoutLogg.Pages.EnterPasswordCode"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#EEEEF6"
    Shell.NavBarIsVisible="False">
    <ScrollView>
     <VerticalStackLayout Padding="28,52,28,40" Spacing="0">
        <!-- Back -->
        <HorizontalStackLayout Margin="0,0,0,36" Spacing="8">
            <Border BackgroundColor="White" HeightRequest="70" 
                    StrokeShape="RoundRectangle 10" StrokeThickness="0" WidthRequest="70">
                <Label FontSize="16" HorizontalOptions="Center" Text="←" TextColor="#374151" VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackTapped" />
                    </Label.GestureRecognizers>
                </Label>
            </Border>
            <Label FontSize="15" Text="Back" TextColor="#374151" VerticalOptions="Center">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackTapped" />
                </Label.GestureRecognizers>
            </Label>
        </HorizontalStackLayout>

        <!-- Icon -->
        <Border
            Margin="0,0,0,28"
            BackgroundColor="#7C3AED"
            HeightRequest="100"
            HorizontalOptions="Center"
            StrokeShape="RoundRectangle 22"
            StrokeThickness="0"
            WidthRequest="100">
            <Label FontSize="36" HorizontalOptions="Center" Text="🔐" VerticalOptions="Center" />
        </Border>

        <!-- Title -->
        <Label FontAttributes="Bold" FontSize="26" HorizontalOptions="Center" HorizontalTextAlignment="Center" Margin="0,0,0,8" Text="Enter the code" TextColor="#111827" />
        <Label x:Name="SubtitleLabel" FontSize="14" HorizontalOptions="Center" HorizontalTextAlignment="Center" Margin="0,0,0,36" Text="We sent a 6-digit code to alex@gmail.com" TextColor="#9CA3AF" />

        <!-- VERIFICATION CODE label -->
        <Label CharacterSpacing="1.2" FontAttributes="Bold" FontSize="11" Margin="4,0,0,14" Text="VERIFICATION CODE" TextColor="#6B7280" />

        <!-- 6 OTP boxes -->
        <Grid ColumnDefinitions="*,8,*,8,*,8,*,8,*,8,*" Margin="0,0,0,20" HeightRequest="74">

            <Border x:Name="Box0" Grid.Column="0"  BackgroundColor="White" Stroke="#E5E7EB" StrokeShape="RoundRectangle 14" StrokeThickness="1.5">
                <Label x:Name="Lbl0" FontAttributes="Bold" FontSize="26" HorizontalOptions="Center" Text="" TextColor="#7C3AED" VerticalOptions="Center" />
            </Border>
            <Border x:Name="Box1" Grid.Column="2"  BackgroundColor="White" Stroke="#E5E7EB" StrokeShape="RoundRectangle 14" StrokeThickness="1.5">
                <Label x:Name="Lbl1" FontAttributes="Bold" FontSize="26" HorizontalOptions="Center" Text="" TextColor="#7C3AED" VerticalOptions="Center" />
            </Border>
            <Border x:Name="Box2" Grid.Column="4"  BackgroundColor="White" Stroke="#E5E7EB" StrokeShape="RoundRectangle 14" StrokeThickness="1.5">
                <Label x:Name="Lbl2" FontAttributes="Bold" FontSize="26" HorizontalOptions="Center" Text="" TextColor="#7C3AED" VerticalOptions="Center" />
            </Border>
            <Border x:Name="Box3" Grid.Column="6"  BackgroundColor="White" Stroke="#E5E7EB" StrokeShape="RoundRectangle 14" StrokeThickness="1.5">
                <Label x:Name="Lbl3" FontAttributes="Bold" FontSize="26" HorizontalOptions="Center" Text="" TextColor="#7C3AED" VerticalOptions="Center" />
            </Border>
            <Border x:Name="Box4" Grid.Column="8"  BackgroundColor="White" Stroke="#E5E7EB" StrokeShape="RoundRectangle 14" StrokeThickness="1.5">
                <Label x:Name="Lbl4" FontAttributes="Bold" FontSize="26" HorizontalOptions="Center" Text="" TextColor="#7C3AED" VerticalOptions="Center" />
            </Border>
            <Border x:Name="Box5" Grid.Column="10" BackgroundColor="White" Stroke="#E5E7EB" StrokeShape="RoundRectangle 14" StrokeThickness="1.5">
                <Label x:Name="Lbl5" FontAttributes="Bold" FontSize="26" HorizontalOptions="Center" Text="·" TextColor="#D1D5DB" VerticalOptions="Center" />
            </Border>

            <!-- Невидимый Entry поверх всех боксов для захвата ввода -->
            <Entry
                x:Name="HiddenEntry"
                Grid.Column="0"
                Grid.ColumnSpan="11"
                BackgroundColor="Transparent"
                IsVisible="False"
                Keyboard="Numeric"
                MaxLength="6"
                Opacity="0"
                TextChanged="OnCodeTextChanged" />
        </Grid>

        <!-- Tap area to focus hidden entry -->
        <BoxView HeightRequest="1" Color="Transparent" Margin="0,0,0,0">
            <BoxView.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnOtpAreaTapped" />
            </BoxView.GestureRecognizers>
        </BoxView>

        <!-- Resend -->
        <HorizontalStackLayout HorizontalOptions="Center" Margin="0,0,0,32" Spacing="4">
            <Label FontSize="14" Text="Didn't receive it?" TextColor="#9CA3AF" VerticalOptions="Center" />
            <Label x:Name="ResendLabel" FontAttributes="Bold" FontSize="14" Text="Resend (28s)" TextColor="#7C3AED" VerticalOptions="Center">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnResendTapped" />
                </Label.GestureRecognizers>
            </Label>
        </HorizontalStackLayout>

        <!-- Verify Code -->
        <Border StrokeShape="RoundRectangle 14" StrokeThickness="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#7C3AED" Offset="0" />
                    <GradientStop Color="#9333EA" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Button BackgroundColor="Transparent" Clicked="OnVerifyCodeClicked" FontAttributes="Bold" FontSize="16" Text="Verify Code" TextColor="White" />
        </Border>

    </VerticalStackLayout>
    </ScrollView>
</ContentPage>
