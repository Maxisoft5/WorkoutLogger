<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="WorkoutLogg.Pages.ForgotPassword"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:loc="clr-namespace:WorkoutLogg.Localization"
    BackgroundColor="#EEEEF6"
    Shell.NavBarIsVisible="False">
    <ScrollView>
        <VerticalStackLayout Padding="28,52,28,40" Spacing="0">

        <!-- Back -->
        <HorizontalStackLayout Margin="0,0,0,36" Spacing="8">
            <Border BackgroundColor="White" HeightRequest="60" StrokeShape="RoundRectangle 10" StrokeThickness="0"
                    WidthRequest="60">
                <Label FontSize="16" HorizontalOptions="Center" Text="←" TextColor="#374151" VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackTapped" />
                    </Label.GestureRecognizers>
                </Label>
            </Border>
            <Label FontSize="15" Text="{loc:Translate Common_Back}" TextColor="#b0a9a9" VerticalOptions="Center">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackTapped" />
                </Label.GestureRecognizers>
            </Label>
        </HorizontalStackLayout>

        <!-- Icon -->
        <Border
            Margin="0,0,0,28"
            BackgroundColor="#7C3AED"
            HeightRequest="100"
            HorizontalOptions="Center"
            StrokeShape="RoundRectangle 22"
            StrokeThickness="0"
            WidthRequest="100">
            <Label FontSize="36" HorizontalOptions="Center" Text="📧" VerticalOptions="Center" />
        </Border>

        <!-- Title -->
        <Label FontAttributes="Bold" FontSize="26" HorizontalOptions="Center" HorizontalTextAlignment="Center" Margin="0,0,0,8" Text="{loc:Translate ForgotPassword_Title}" TextColor="#111827" />
        <Label FontSize="14" HorizontalOptions="Center" HorizontalTextAlignment="Center" Margin="0,0,0,36" Text="{loc:Translate ForgotPassword_Subtitle}" TextColor="#9CA3AF" />

        <!-- EMAIL ADDRESS -->
        <Label CharacterSpacing="1.2" FontAttributes="Bold" FontSize="11" Margin="4,0,0,8" Text="{loc:Translate ForgotPassword_EmailAddress}" TextColor="#6B7280" />
        <Border Margin="0,0,0,28" BackgroundColor="White" Stroke="#E5E7EB" StrokeShape="RoundRectangle 12" StrokeThickness="1.5">
            <Entry x:Name="EmailEntry" BackgroundColor="Transparent" FontSize="15" Keyboard="Email" Margin="14,0" Placeholder="alex@gmail.com" PlaceholderColor="#D1D5DB" TextColor="#111827" VerticalOptions="Center" />
        </Border>

        <!-- Send Reset Code -->
        <Border StrokeShape="RoundRectangle 14" StrokeThickness="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#7C3AED" Offset="0" />
                    <GradientStop Color="#9333EA" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Button BackgroundColor="Transparent" Clicked="OnSendResetCodeClicked" FontAttributes="Bold" FontSize="16" Text="{loc:Translate ForgotPassword_SendCode}" TextColor="White" />
        </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
