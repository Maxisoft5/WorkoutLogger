<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="WorkoutLogg.Pages.AddWorkoutPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#EEEEF6"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Padding="20,52,20,16">
            <Button Grid.Column="0"
                    BackgroundColor="Transparent"
                    Clicked="OnBackClicked"
                    FontSize="22"
                    Text="‹"
                    TextColor="#7C3AED"
                    Padding="0"
                    VerticalOptions="Center" />
            <Label Grid.Column="1"
                   FontAttributes="Bold"
                   FontSize="20"
                   HorizontalOptions="Center"
                   Text="New Workout"
                   TextColor="#111827"
                   VerticalOptions="Center" />
        </Grid>

        <!-- Scrollable form -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20,0,20,20" Spacing="16">

                <!-- Workout Type -->
                <Border BackgroundColor="White" Padding="16" Stroke="#F3F4F6" StrokeShape="RoundRectangle 16" StrokeThickness="1">
                    <VerticalStackLayout Spacing="12">
                        <Label FontAttributes="Bold" FontSize="13" Text="Workout Type" TextColor="#6B7280" />
                        <ScrollView HorizontalScrollBarVisibility="Never" Orientation="Horizontal">
                            <HorizontalStackLayout x:Name="TypeChips" Spacing="8" />
                        </ScrollView>
                    </VerticalStackLayout>
                </Border>

                <!-- Date & Duration -->
                <Border BackgroundColor="White" Padding="16" Stroke="#F3F4F6" StrokeShape="RoundRectangle 16" StrokeThickness="1">
                    <VerticalStackLayout Spacing="12">
                        <Label FontAttributes="Bold" FontSize="13" Text="Date" TextColor="#6B7280" />
                        <DatePicker x:Name="WorkoutDatePicker"
                                    MinimumDate="01/01/2020"
                                    MaximumDate="12/31/2030"
                                    Format="dddd, d MMMM yyyy"
                                    TextColor="#111827"
                                    FontSize="15" />
                        <Grid ColumnDefinitions="*,16,*" ColumnSpacing="0">
                            <VerticalStackLayout Grid.Column="0" Spacing="4">
                                <Label FontSize="12" Text="Start time" TextColor="#9CA3AF" />
                                <TimePicker x:Name="StartTimePicker" TextColor="#111827" FontSize="15" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="2" Spacing="4">
                                <Label FontSize="12" Text="End time" TextColor="#9CA3AF" />
                                <TimePicker x:Name="EndTimePicker" TextColor="#111827" FontSize="15" />
                            </VerticalStackLayout>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Exercises -->
                <Grid ColumnDefinitions="*,Auto">
                    <Label Grid.Column="0"
                           FontAttributes="Bold"
                           FontSize="17"
                           Text="Exercises"
                           TextColor="#111827"
                           VerticalOptions="Center" />
                    <Border Grid.Column="1"
                            BackgroundColor="#7C3AED"
                            Padding="12,8"
                            StrokeShape="RoundRectangle 12"
                            StrokeThickness="0">
                        <Label FontAttributes="Bold"
                               FontSize="13"
                               Text="+ Add"
                               TextColor="White">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnAddExerciseTapped" />
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>
                </Grid>

                <VerticalStackLayout x:Name="ExercisesList" Spacing="12" />

                <!-- Empty state for exercises -->
                <Border x:Name="ExercisesEmpty"
                        BackgroundColor="White"
                        Padding="24"
                        Stroke="#F3F4F6"
                        StrokeShape="RoundRectangle 16"
                        StrokeThickness="1">
                    <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Label FontSize="32" HorizontalOptions="Center" Text="🏋️" />
                        <Label FontSize="14"
                               HorizontalOptions="Center"
                               Text="Tap &quot;+ Add&quot; to add your first exercise"
                               TextColor="#9CA3AF" />
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Save button -->
        <Border Grid.Row="2"
                BackgroundColor="White"
                Padding="20,16"
                Stroke="#F3F4F6"
                StrokeShape="RoundRectangle 0"
                StrokeThickness="0">
            <Border.Shadow>
                <Shadow Brush="#000000" Offset="0,-2" Radius="12" Opacity="0.06" />
            </Border.Shadow>
            <Button BackgroundColor="#7C3AED"
                    Clicked="OnSaveClicked"
                    CornerRadius="14"
                    FontAttributes="Bold"
                    FontSize="16"
                    HeightRequest="52"
                    Text="Save Workout"
                    TextColor="White" />
        </Border>

    </Grid>
</ContentPage>
